#!/usr/bin/env bash

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

# Select output directory via GUI picker
OUTPUT_DIR=$(kdialog --getexistingdirectory "$HOME" --title "📁 Select Download Folder")
[ -z "$OUTPUT_DIR" ] && exit 0

# Accept URL as argument or prompt in terminal
if [ $# -ge 1 ]; then
    URL="$1"
else
    echo -e "${CYAN}${BOLD}🎬 yt-download${RESET}"
    read -rp "$(echo -e "${YELLOW}🔗 Enter YouTube URL: ${RESET}")" URL
fi
[ -z "$URL" ] && exit 0

echo -e "\n${CYAN}📥 Starting download...${RESET}"
echo -e "${YELLOW}📂 Output folder: ${BOLD}$OUTPUT_DIR${RESET}\n"

# Pick Chrome profile for cookies
CHROME_LOCAL_STATE="$HOME/.config/google-chrome/Local State"
declare -a MENU_ARGS
while IFS=$'\t' read -r key name; do
    MENU_ARGS+=("$key" "$name")
done < <(jq -r '.profile.info_cache | to_entries[] | "\(.key)\t\(.value.name)"' "$CHROME_LOCAL_STATE")
PROFILE_KEY=$(kdialog --title "Chrome Profile" --menu "Select Chrome profile for cookies:" "${MENU_ARGS[@]}")

TMPFILE=$(mktemp)

yt-dlp \
    --print-to-file after_move:filepath "$TMPFILE" \
    --cookies-from-browser "chrome:$PROFILE_KEY" \
    --write-subs \
    --write-auto-subs \
    --embed-subs \
    --sub-langs "en.*" \
    --embed-thumbnail \
    --embed-metadata \
    --embed-chapters \
    --merge-output-format mkv \
    -f "bv*+ba/b" \
    -o "$OUTPUT_DIR/%(title)s.%(ext)s" \
    "$URL"

STATUS=$?
FINAL_FILE=$(tail -n1 "$TMPFILE")
rm -f "$TMPFILE"

if [ "$STATUS" -eq 0 ] && [ -f "$FINAL_FILE" ]; then

    BASE="${FINAL_FILE%.mkv}"

    rm -f \
        "${BASE}.vtt" \
        "${BASE}".*.vtt \
        "${BASE}.srt" \
        "${BASE}".*.srt \
        "${BASE}.ass" \
        "${BASE}".*.ass \
        "${BASE}.webp" \
        "${BASE}.jpg" \
        "${BASE}.jpeg" \
        "${BASE}.png"

    echo -e "\n${GREEN}${BOLD}✅ Download complete!${RESET}"
    echo -e "${GREEN}🎞️  Saved to: ${BOLD}$FINAL_FILE${RESET}"
else
    echo -e "\n${RED}${BOLD}❌ Download failed.${RESET}" >&2
    exit 1
fi
